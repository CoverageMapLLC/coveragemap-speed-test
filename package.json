{
  "name": "@coveragemap/speed-test",
  "version": "0.2.0",
  "description": "CoverageMap.com speed test library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:deploy": "vitest run --config vitest.deploy.config.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "speed-test",
    "coverage-map",
    "network-testing",
    "websocket"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CoverageMapLLC/coveragemap-speed-test.git"
  },
  "bugs": {
    "url": "https://github.com/CoverageMapLLC/coveragemap-speed-test/issues"
  },
  "homepage": "https://github.com/CoverageMapLLC/coveragemap-speed-test#readme",
  "author": "CoverageMap",
  "license": "Apache-2.0",
  "dependencies": {
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
